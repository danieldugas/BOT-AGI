<mujoco model="g1_manipulation_scene">
  <include file="g1_with_hand.xml"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <statistic center="0.3 0 1.0" extent="1.5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
             rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_mat" rgba="0.55 0.4 0.25 1"/>
    <material name="cube_mat" rgba="0.9 0.15 0.15 1"/>
    <material name="target_mat" rgba="0.15 0.85 0.25 1"/>
  </asset>

  <worldbody>
    <light pos="1 0 2.5" dir="-0.3 0 -1" directional="true"/>
    <light pos="-1 1 2.0" dir="0.3 -0.3 -1" diffuse="0.4 0.4 0.4"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table in front of the robot -->
    <body name="table" pos="0.45 0 0.375">
      <geom name="table_top" type="box" size="0.35 0.45 0.02" pos="0 0 0.355"
            material="table_mat" friction="1.0 0.01 0.001"/>
      <geom name="table_leg_1" type="box" size="0.02 0.02 0.375" pos="0.3 0.4 0" material="table_mat"/>
      <geom name="table_leg_2" type="box" size="0.02 0.02 0.375" pos="0.3 -0.4 0" material="table_mat"/>
      <geom name="table_leg_3" type="box" size="0.02 0.02 0.375" pos="-0.3 0.4 0" material="table_mat"/>
      <geom name="table_leg_4" type="box" size="0.02 0.02 0.375" pos="-0.3 -0.4 0" material="table_mat"/>
    </body>

    <!-- Target disk (green) on the table, left of center from robot view -->
    <body name="target" pos="0.35 0.0 0.751">
      <geom name="target_disk" type="cylinder" size="0.05 0.002" material="target_mat"
            contype="0" conaffinity="0"/>
    </body>

    <!-- Red cube (5x5x5 cm) on the table, right of center from robot view -->
    <body name="red_cube" pos="0.32 -0.3 0.78">
      <freejoint name="cube_free"/>
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.000042 0.000042 0.000042"/>
      <geom name="cube_geom" type="box" size="0.025 0.025 0.025" material="cube_mat"
            friction="1.0 0.02 0.001" condim="4"/>
    </body>

    <!-- Cameras (xyaxes are camera x/y in world; camera looks along -z) -->
    <camera name="front_view" pos="1.6 0 1.25" xyaxes="0 1 0 -0.26 0 0.97" fovy="55"/>
    <camera name="side_view" pos="0.45 -1.6 1.25" xyaxes="1 0 0 0 0.13 0.99" fovy="55"/>
  </worldbody>
</mujoco>
